            playSound('success');
            saveUserData();
            renderSanctuary();
        }

        /* -----------------------------------------
         * STREAMING_CHUNK: Upgrading UI timers and circular gauges
         * ----------------------------------------- */
        function updateUI() {
            const m = Math.floor(pomoState.timeLeft / 60).toString().padStart(2, '0');
            const s = (pomoState.timeLeft % 60).toString().padStart(2, '0');
            timerDisplay.textContent = `${m}:${s}`;

            const themeKey = pomoState.currentRoundTheme || 'classic';
            const themeInfo = DUO_THEMES[themeKey] || DUO_THEMES.classic;

            if (pomoState.currentMode === 'focus') {
                modeDisplay.textContent = `FOCUS TIME (${themeInfo.name} 알 품기)`;
                modeDisplay.style.color = themeInfo.main;
                progressRing.setAttribute('stroke', themeInfo.main);
            } else if (pomoState.currentMode === 'shortBreak') {
                modeDisplay.textContent = "SHORT BREAK (달콤한 평화)";
                modeDisplay.style.color = '#1899eb';
                progressRing.setAttribute('stroke', '#1899eb');
            } else {
                modeDisplay.textContent = "LONG BREAK (대꿀잠 시간)";
                modeDisplay.style.color = '#6366f1';
                progressRing.setAttribute('stroke', '#6366f1');
            }

            const circumference = 2 * Math.PI * 116; 
            const progressRatio = pomoState.timeLeft / pomoState.totalDurationOfSession;
            const strokeOffset = circumference - (progressRatio * circumference);
            progressRing.style.strokeDasharray = `${circumference}`;
            progressRing.style.strokeDashoffset = `${strokeOffset}`;

            healthBar.style.width = `${pomoState.health}%`;
            healthText.textContent = `${Math.round(pomoState.health)}%`;
            
            if (pomoState.health > 50) {
                healthBar.className = "bg-green-500 h-full transition-all duration-300";
            } else if (pomoState.health > 25) {
                healthBar.className = "bg-amber-500 h-full transition-all duration-300";
            } else {
                healthBar.className = "bg-red-500 h-full transition-all duration-300";
            }

            streakText.textContent = `${pomoState.completedStreak}회 성공`;
            renderDuoGraphic();
        }

        /* -----------------------------------------
         * STREAMING_CHUNK: Managing study intervals & automatic phase progression
         * ----------------------------------------- */
        function syncTimeSettings() {
            pomoState.focusTime = parseInt(inputFocus.value, 10) * 60 || 25 * 60;
            pomoState.shortBreakTime = parseInt(inputShort.value, 10) * 60 || 5 * 60;
            pomoState.longBreakTime = parseInt(inputLong.value, 10) * 60 || 15 * 60;

            if (!pomoState.isRunning) {
                resetSessionTimer();
            }
        }

        function resetSessionTimer() {
            if (pomoState.currentMode === 'focus') {
                pomoState.timeLeft = pomoState.focusTime;
            } else if (pomoState.currentMode === 'shortBreak') {
                pomoState.timeLeft = pomoState.shortBreakTime;
            } else {
                pomoState.timeLeft = pomoState.longBreakTime;
            }
            pomoState.totalDurationOfSession = pomoState.timeLeft;
            updateUI();
        }

        function toggleTimer() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            }
            if (audioCtx.state === 'suspended') {
                audioCtx.resume();
            }

            if (pomoState.isRunning) {
                pomoState.isRunning = false;
                btnStart.textContent = "공부 시작!";
                btnStart.className = "btn-duo-green text-white py-3.5 px-4 rounded-2xl font-black text-lg focus:outline-none shadow-sm";
                clearInterval(pomoState.intervalId);
                pomoState.intervalId = null;
            } else {
                pomoState.isRunning = true;
                if (pomoState.currentMode === 'focus') {
                    btnStart.textContent = "일시 정지";
                    btnStart.className = "btn-duo-danger text-white py-3.5 px-4 rounded-2xl font-black text-lg focus:outline-none shadow-sm";
                    speakRandom('healthy');
                } else {
                    btnStart.textContent = "휴식 중지";
                    btnStart.className = "btn-duo-danger text-white py-3.5 px-4 rounded-2xl font-black text-lg focus:outline-none shadow-sm";
                    speakRandom('break');
                }
                pomoState.intervalId = setInterval(tickTimer, 1000);
            }
            updateUI();
        }

        // 실시간 화면 이탈(Page Visibility API) 및 패널티 경보음 매핑
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                if (pomoState.isRunning && pomoState.currentMode === 'focus') {
                    pomoState.isDistracted = true;
                    document.body.classList.add('emergency-active');
                    
                    defenseBadge.innerHTML = `<span class="w-2 h-2 rounded-full bg-red-500 animate-ping"></span><span>EMERGENCY</span>`;
                    defenseBadge.className = "flex items-center space-x-1 px-2 py-1 bg-red-100 text-red-700 text-[10px] font-black rounded-full";
                    
                    renderDuoGraphic();
                    speakRandom('distracted');
                    playSound('warn');
                }
            } else {
                if (pomoState.isDistracted) {
                    pomoState.isDistracted = false;
                    document.body.classList.remove('emergency-active');

                    defenseBadge.innerHTML = `<span class="w-2 h-2 rounded-full bg-green-500 animate-ping"></span><span>SAFE</span>`;
                    defenseBadge.className = "flex items-center space-x-1 px-2 py-1 bg-green-100 text-green-700 text-[10px] font-black rounded-full";

                    renderDuoGraphic();
                    speechBubble.innerHTML = `"휴... 딴짓 멈추고 돌아와줘서 다행이에요. 계속 진행합시다!"`;
                    playSound('relief');
                }
            }
        });

        // 1초 단위 타이머 스케줄링 인터벌 제어
        function tickTimer() {
            const multiplier = pomoState.isDevMode ? 60 : 1;

            for (let k = 0; k < multiplier; k++) {
                if (pomoState.timeLeft <= 0) {
                    clearInterval(pomoState.intervalId);
                    pomoState.intervalId = null;
                    pomoState.isRunning = false;
                    handleSessionComplete();
                    return;
                }

                // 딴짓으로 이탈해 있을 경우 체력 대량 감쇄 패널티 부여
                if (pomoState.isDistracted && pomoState.currentMode === 'focus') {
                    pomoState.health -= 1.5; 
                    if (pomoState.health <= 0) {
                        pomoState.health = 0;
                        clearInterval(pomoState.intervalId);
                        pomoState.intervalId = null;
                        pomoState.isRunning = false;
                        triggerFailure();
                        return;
                    }
                    if (Math.random() < 0.1) {
                        playSound('warn');
                    }
                } else {
                    if (pomoState.health < 100) {
                        pomoState.health = Math.min(100, pomoState.health + 0.1);
                    }
                }

                pomoState.timeLeft--;
            }

            updateUI();

            if (pomoState.timeLeft % 20 === 0 && pomoState.isRunning) {
                if (pomoState.isDistracted) {
                    speakRandom('distracted');
                } else if (pomoState.currentMode === 'focus') {
                    speakRandom('healthy');
                }
            }
        }

        /* -----------------------------------------
         * STREAMING_CHUNK: Delivering dynamic stage-wise rewards and cycling colors
         * ----------------------------------------- */
        function handleSessionComplete() {
            playSound('success');

            if (pomoState.currentMode === 'focus') {
                pomoState.completedRounds++;
                pomoState.completedStreak++;

                triggerRewardModal();
            } else {
                pomoState.currentMode = 'focus';
                
                // 새로운 무작위 테마 색상 갱신
                pomoState.currentRoundTheme = pomoState.roundColorSequence[pomoState.completedRounds % 5];
                const activeThemeInfo = DUO_THEMES[pomoState.currentRoundTheme];

                openAlertModal(
                    "⏰ 휴식 끝! 다시 집중합시다!", 
                    `새로운 ${activeThemeInfo.name} 알이 배달되었습니다. 딴짓하지 말고 멋지게 부화시켜 보세요!`, 
                    "🦉", 
                    () => {
                        btnStart.textContent = "공부 시작!";
                        btnStart.className = "btn-duo-green text-white py-3.5 px-4 rounded-2xl font-black text-lg focus:outline-none shadow-sm";
                        renderRoundSlots();
                        resetSessionTimer();
                        saveUserData();
                    }
                );
            }
        }

        // 보상 지급 연계 모달 렌더링
        function triggerRewardModal() {
            modalEmoji.textContent = "🎁";
            modalTitle.textContent = `${pomoState.completedRounds}단계 성공!`;
            modalTitle.className = "text-2xl font-black text-[#58cc02]";
            gameoverReason.textContent = "훌륭합니다! 듀오가 당신의 온전한 노력을 격려하며 특별 선물을 보냈습니다. 아래 유용한 보상 중 하나를 획득하세요.";
            
            rewardChoices.classList.remove('hidden');
            btnRestart.classList.add('hidden');

            gameoverModal.classList.remove('hidden');
        }

        // 보상 1: 10분 추가 휴식권
        btnRewardRest.addEventListener('click', () => {
            pomoState.shortBreakTime += 10 * 60;
            claimRewardSuccess("☕ 10분 휴식 추가권 획득!", "이번 짧은 휴식 시간이 총 15분으로 증가했습니다.");
        });

        // 보상 2: 100 FP 포인트 획득
        btnRewardPoints.addEventListener('click', () => {
            pomoState.fp += 100;
            claimRewardSuccess("🧪 100 FP 획득 성공!", "사육장에 보관 중인 듀오 알을 즉시 길러낼 수 있습니다.");
        });

        function claimRewardSuccess(title, sub) {
            rewardChoices.classList.add('hidden');
            btnRestart.classList.remove('hidden');
            gameoverModal.classList.add('hidden');

            // 획득한 고유 색상 테마의 알 생성 및 도감 보존
            const randomAdj = DUO_ADJECTIVES[Math.floor(Math.random() * DUO_ADJECTIVES.length)];
            const activeThemeKey = pomoState.currentRoundTheme || 'classic';
            const targetColorName = DUO_THEMES[activeThemeKey].name;

            const newDuoItem = {
                id: 'duo-' + Date.now(),
                name: `${randomAdj} ${targetColorName} 알`,
                level: 1,
                maxLevel: 5,
                themeKey: activeThemeKey
            };
            
            pomoState.inventory.push(newDuoItem);

            const justFinishedRound = pomoState.completedRounds;

            if (pomoState.completedRounds >= pomoState.roundGoal) {
                pomoState.currentMode = 'longBreak';
                pomoState.completedRounds = 0; 

                openAlertModal(
                    `🎉 ${justFinishedRound}단계 성공! 4라운드 올클리어`, 
                    `오늘 집중 4단계를 무사히 전부 완료해냈습니다! 이제 ${pomoState.longBreakTime / 60}분간 행복한 긴 휴식에 들어갑니다.`, 
                    "👑",
                    () => {
                        btnStart.textContent = "휴식 시작하기";
                        btnStart.className = "btn-duo-blue text-white py-3.5 px-4 rounded-2xl font-black text-lg focus:outline-none shadow-sm";
                        renderRoundSlots();
                        resetSessionTimer();
                        saveUserData();
                        renderSanctuary();
                    }
                );
            } else {
                pomoState.currentMode = 'shortBreak';

                openAlertModal(
                    `🎉 ${justFinishedRound}단계 성공! ${title}`, 
                    `${sub} 이제 평화로운 휴식이 보장됩니다.`, 
                    "🐣",
                    () => {
                        btnStart.textContent = "휴식 시작하기";
                        btnStart.className = "btn-duo-blue text-white py-3.5 px-4 rounded-2xl font-black text-lg focus:outline-none shadow-sm";
                        renderRoundSlots();
                        resetSessionTimer();
                        saveUserData();
                        renderSanctuary();
                    }
                );
            }
        }

        // 딴짓 과다 체력 0으로 인한 아웃 실패 모달 가동
        function triggerFailure() {
            playSound('fail');
            pomoState.completedStreak = 0; 
            saveUserData();

            modalEmoji.textContent = "🔪";
            modalTitle.textContent = "인내심의 한계 폭발!";
            modalTitle.className = "text-2xl font-black text-red-600";
            gameoverReason.textContent = `"집중 중에 딴짓을 하시다니... 제 인내심도 한계에 도달했습니다. 오늘 밤 당신의 방에 조용히 칼 한 자루가 배달될지도 모르겠네요."`;
            
            rewardChoices.classList.add('hidden');
            btnRestart.classList.remove('hidden');
            btnRestart.textContent = "용서를 빌고 처음부터 다시 시작";
            btnRestart.className = "w-full btn-duo-danger text-white py-3.5 rounded-2xl font-black shadow-sm";
            
            modalActionCallback = () => {
                resetAll();
            };
            gameoverModal.classList.remove('hidden');
        }

        function openAlertModal(title, text, emoji, callback) {
            modalEmoji.textContent = emoji;
            modalTitle.textContent = title;
            modalTitle.className = "text-2xl font-black text-[#58cc02]";
            gameoverReason.textContent = text;
            
            rewardChoices.classList.add('hidden');
            btnRestart.classList.remove('hidden');
            btnRestart.textContent = "확인";
            btnRestart.className = "w-full btn-duo-green text-white py-3.5 rounded-2xl font-black shadow-sm";
            
            modalActionCallback = callback || null;
            gameoverModal.classList.remove('hidden');
        }

        function resetAll() {
            pomoState.isRunning = false;
            pomoState.currentMode = 'focus';
            
            // 리셋 시 새로운 무중복 컬러 세팅으로 재빌드
            pomoState.roundColorSequence = generateRoundColors();
            pomoState.currentRoundTheme = pomoState.roundColorSequence[0]; 

            pomoState.focusTime = parseInt(inputFocus.value, 10) * 60 || 25 * 60;
            pomoState.shortBreakTime = parseInt(inputShort.value, 10) * 60 || 5 * 60;
            pomoState.longBreakTime = parseInt(inputLong.value, 10) * 60 || 15 * 60;

            pomoState.timeLeft = pomoState.focusTime;
            pomoState.totalDurationOfSession = pomoState.timeLeft;
            pomoState.health = 100;
            pomoState.isDistracted = false;
            pomoState.completedRounds = 0;

            document.body.classList.remove('emergency-active');
            clearInterval(pomoState.intervalId);
            pomoState.intervalId = null;

            btnStart.textContent = "공부 시작!";
            btnStart.className = "btn-duo-green text-white py-3.5 px-4 rounded-2xl font-black text-lg focus:outline-none shadow-sm";
            
            defenseBadge.innerHTML = `<span class="w-2 h-2 rounded-full bg-green-500 animate-ping"></span><span>SAFE</span>`;
            defenseBadge.className = "flex items-center space-x-1 px-2 py-1 bg-green-100 text-green-700 text-[10px] font-black rounded-full";

            renderRoundSlots();
            updateUI();
            speechBubble.innerHTML = `"정신을 딴딴히 붙잡고 다시 집중을 시작하세요. 딴짓하는 즉시 다시 찾아옵니다."`;
        }

        /* -----------------------------------------
         * STREAMING_CHUNK: Managing Firestore cloud saving
         * ----------------------------------------- */
        async function initFirebase() {
            const firebaseConfig = typeof __firebase_config !== 'undefined' ? JSON.parse(__firebase_config) : null;
            if (!firebaseConfig) {
                loadLocalBackup();
                return;
            }

            try {
                const app = initializeApp(firebaseConfig);
                db = getFirestore(app);
                auth = getAuth(app);

                await signInAnonymously(auth);
                userId = auth.currentUser?.uid;
                
                if (userId) {
                    await fetchUserData();
                }
            } catch(e) {
                console.log("Firebase 연결 제한으로 인한 대체 로드:", e);
                loadLocalBackup();
            }
        }

        async function fetchUserData() {
            if (!db || !userId) return;
            try {
                const userDocRef = doc(db, 'artifacts', appId, 'users', userId, 'profile', 'userdata');
                const userSnap = await getDoc(userDocRef);
                if (userSnap.exists()) {
                    const data = userSnap.data();
                    pomoState.completedStreak = data.completedStreak || 0;
                    pomoState.fp = data.fp ?? 100;
                    pomoState.inventory = data.inventory || [];
                }
                renderSanctuary();
                updateUI();
            } catch(err) {
                console.log("DB 데이터 로드 에러:", err);
            }
        }

        async function saveUserData() {
            if (!db || !userId) {
                saveLocalBackup();
                return;
            }
            try {
                const userDocRef = doc(db, 'artifacts', appId, 'users', userId, 'profile', 'userdata');
                await setDoc(userDocRef, {
                    completedStreak: pomoState.completedStreak,
                    fp: pomoState.fp,
                    inventory: pomoState.inventory
                }, { merge: true });
            } catch(e) {
                saveLocalBackup();
            }
        }

        function saveLocalBackup() {
            const dump = {
                completedStreak: pomoState.completedStreak,
                fp: pomoState.fp,
                inventory: pomoState.inventory
            };
            try {
                localStorage.setItem('duo_pomo_local_colorful_v2', JSON.stringify(dump));
            } catch(e){}
        }

        function loadLocalBackup() {
            try {
                const raw = localStorage.getItem('duo_pomo_local_colorful_v2');
                if (raw) {
                    const parsed = JSON.parse(raw);
                    pomoState.completedStreak = parsed.completedStreak || 0;
                    pomoState.fp = parsed.fp ?? 100;
                    pomoState.inventory = parsed.inventory || [];
                }
            } catch(e){}
            renderSanctuary();
            updateUI();
        }

        /* -----------------------------------------
         * STREAMING_CHUNK: Binding Event listeners and launching application
         * ----------------------------------------- */
        tabTimer.addEventListener('click', () => {
            viewTimer.classList.remove('hidden');
            viewSanctuary.classList.add('hidden');
            tabTimer.className = "py-2 rounded-xl font-bold text-sm bg-white border-2 border-[#58cc02] text-[#58cc02] shadow-sm";
            tabSanctuary.className = "py-2 rounded-xl font-bold text-sm bg-white border-2 border-gray-200 text-gray-400";
        });

        tabSanctuary.addEventListener('click', () => {
            viewTimer.classList.add('hidden');
            viewSanctuary.classList.remove('hidden');
            tabSanctuary.className = "py-2 rounded-xl font-bold text-sm bg-white border-2 border-[#58cc02] text-[#58cc02] shadow-sm";
            tabTimer.className = "py-2 rounded-xl font-bold text-sm bg-white border-2 border-gray-200 text-gray-400";
            renderSanctuary();
        });

        btnStart.addEventListener('click', toggleTimer);
        btnReset.addEventListener('click', resetAll);

        inputFocus.addEventListener('change', syncTimeSettings);
        inputShort.addEventListener('change', syncTimeSettings);
        inputLong.addEventListener('change', syncTimeSettings);

        btnSoundToggle.addEventListener('click', () => {
            soundEnabled = !soundEnabled;
            btnSoundToggle.textContent = soundEnabled ? "ON 🔊" : "OFF 🔇";
            btnSoundToggle.className = soundEnabled 
                ? "px-2.5 py-1 text-[10px] font-bold rounded-full bg-green-100 text-green-700 border border-green-300"
                : "px-2.5 py-1 text-[10px] font-bold rounded-full bg-gray-100 text-gray-400 border border-gray-300";
        });

        devSpeedCheckbox.addEventListener('change', (e) => {
            pomoState.isDevMode = e.target.checked;
        });

        btnRestart.addEventListener('click', () => {
            gameoverModal.classList.add('hidden');
            if (typeof modalActionCallback === 'function') {
                modalActionCallback();
                modalActionCallback = null;
            } else {
                resetAll();
            }
        });

        // 브라우저 윈도우 최초 기동 시 데이터 마운팅 및 초기화
        window.onload = function() {
            pomoState.roundColorSequence = generateRoundColors();
            pomoState.currentRoundTheme = pomoState.roundColorSequence[0];

            initFirebase();
            renderRoundSlots();
            resetSessionTimer();
            updateUI();
        };
    </script>
</body>
</html>
