<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Duo Focus Pomodoro: 컬러풀 듀오 사육장</title>
    <!-- Tailwind CSS 로드 -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts: Inter 및 한글 고딕 폰트 로드 -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Noto+Sans+KR:wght@400;700;900&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Noto Sans KR', 'Inter', sans-serif;
            background-color: #f7f7f7;
            transition: background-color 0.5s ease, color 0.5s ease;
        }
        /* 듀오링고 스타일의 입체형 3D 버튼 정의 */
        .btn-duo-green {
            background-color: #58cc02;
            border-bottom: 5px solid #46a302;
            transition: all 0.1s ease;
        }
        .btn-duo-green:hover {
            background-color: #61e002;
        }
        .btn-duo-green:active {
            border-bottom-width: 0px;
            transform: translateY(5px);
        }
        .btn-duo-blue {
            background-color: #1899eb;
            border-bottom: 5px solid #1072b0;
            transition: all 0.1s ease;
        }
        .btn-duo-blue:hover {
            background-color: #21a6f8;
        }
        .btn-duo-blue:active {
            border-bottom-width: 0px;
            transform: translateY(5px);
        }
        .btn-duo-gray {
            background-color: #e5e5e5;
            border-bottom: 5px solid #afafaf;
            color: #4b4b4b;
            transition: all 0.1s ease;
        }
        .btn-duo-gray:hover {
            background-color: #f0f0f0;
        }
        .btn-duo-gray:active {
            border-bottom-width: 0px;
            transform: translateY(5px);
        }
        .btn-duo-danger {
            background-color: #ff4b4b;
            border-bottom: 5px solid #ea2b2b;
            color: white;
            transition: all 0.1s ease;
        }
        .btn-duo-danger:hover {
            background-color: #ff6060;
        }
        .btn-duo-danger:active {
            border-bottom-width: 0px;
            transform: translateY(5px);
        }
        /* 둥둥 떠 있는 듯한 애니메이션 효과 */
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }
        .duo-float {
            animation: float 4s infinite ease-in-out;
        }
        /* 부화 전 알 흔들림 애니메이션 효과 */
        @keyframes eggShake {
            0%, 100% { transform: rotate(0deg) scale(1); }
            25% { transform: rotate(-6deg) scale(1.02); }
            75% { transform: rotate(6deg) scale(1.02); }
        }
        .egg-shake {
            animation: eggShake 1.2s infinite ease-in-out;
        }
        /* 딴짓 감지 시 비상 경고 적색 화면 교차 블링킹 효과 */
        @keyframes redAlert {
            0%, 100% { background-color: #f7f7f7; }
            50% { background-color: #fee2e2; }
        }
        .emergency-active {
            animation: redAlert 0.8s infinite;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-between p-4 overflow-x-hidden">

    <!-- 상단 헤더 영역 -->
    <header class="w-full max-w-md flex justify-between items-center py-3 px-5 bg-white rounded-2xl shadow-sm border-2 border-gray-200 mt-2">
        <div class="flex items-center space-x-2">
            <span class="text-3xl">🦉</span>
            <div class="flex flex-col">
                <span class="font-extrabold text-lg text-[#58cc02] leading-none tracking-tight">DUO POMO</span>
                <span class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-0.5">Focus & Evolve</span>
            </div>
        </div>
        <div class="flex items-center space-x-3">
            <div id="streak-counter" class="flex items-center space-x-1 px-2.5 py-1 bg-amber-50 text-amber-600 text-xs font-bold rounded-xl border border-amber-200 shadow-sm">
                <span>🔥</span>
                <span id="streak-text">0회 성공</span>
            </div>
            <div id="defense-badge" class="flex items-center space-x-1 px-2 py-1 bg-green-100 text-green-700 text-[10px] font-black rounded-full uppercase">
                <span class="w-2 h-2 rounded-full bg-green-500 animate-ping"></span>
                <span>SAFE</span>
            </div>
        </div>
    </header>

    <!-- 타이머 vs 사육장 도감 탭 내비게이션 -->
    <div class="w-full max-w-md grid grid-cols-2 gap-2 mt-4">
        <button id="tab-timer" class="py-2 rounded-xl font-bold text-sm bg-white border-2 border-[#58cc02] text-[#58cc02] shadow-sm">⏳ 집중 타이머</button>
        <button id="tab-sanctuary" class="py-2 rounded-xl font-bold text-sm bg-white border-2 border-gray-200 text-gray-400">🏡 나의 듀오 사육장 (<span id="sanctuary-count">0</span>)</button>
    </div>

    <!-- 메인 타이머 뷰 -->
    <main id="view-timer" class="w-full max-w-md flex-1 flex flex-col items-center justify-center my-4 space-y-5">
        
        <!-- 대사 대화창 -->
        <div class="relative w-full px-2">
            <div id="speech-bubble" class="bg-white border-2 border-gray-200 p-4 rounded-2xl text-center font-bold text-gray-700 text-sm shadow-sm relative after:absolute after:bottom-[-10px] after:left-1/2 after:-translate-x-1/2 after:border-t-[10px] after:border-t-white after:border-x-[10px] after:border-x-transparent before:absolute before:bottom-[-13px] before:left-1/2 before:-translate-x-1/2 before:border-t-[11px] before:border-t-gray-200 before:border-x-[11px] before:border-x-transparent">
                "안녕? 난 듀오야! 딴짓할 생각은 버려. 집중하지 않으면 내 칼날이 울부짖을 거야!"
            </div>
        </div>

        <!-- 듀오를 감싼 원형 타이머 링 -->
        <div class="relative flex items-center justify-center w-64 h-64 mx-auto my-2">
            <!-- 외부 원형 프로그레스 바 -->
            <svg class="absolute inset-0 w-full h-full -rotate-90">
                <circle cx="128" cy="128" r="116" stroke="#e5e7eb" stroke-width="12" fill="transparent" />
                <circle id="timer-progress-ring" cx="128" cy="128" r="116" stroke="#58cc02" stroke-width="12" stroke-dasharray="728.8" stroke-dashoffset="0" stroke-linecap="round" fill="transparent" class="transition-all duration-300" />
            </svg>
            
            <!-- 중심의 듀오 캐릭터 그래픽 마운트 영역 -->
            <div id="duo-container" class="w-48 h-48 flex items-center justify-center relative duo-float z-10">
                <!-- SVG 코드가 동적으로 마운트됩니다 -->
            </div>
        </div>

        <!-- 상태 대시보드 카드 -->
        <div class="w-full bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-200 space-y-4">
            
            <!-- 듀오의 남은 인내심 (체력 바) -->
            <div class="space-y-1">
                <div class="flex justify-between text-xs font-extrabold">
                    <span class="text-red-500">💥 듀오의 남은 인내심 (체력)</span>
                    <span id="health-text" class="text-red-500">100%</span>
                </div>
                <div class="w-full bg-gray-100 h-3 rounded-full overflow-hidden border border-gray-200">
                    <div id="health-bar" class="bg-red-500 h-full w-full transition-all duration-300"></div>
                </div>
            </div>

            <!-- 타임 디스플레이 및 현재 모드 명시 -->
            <div class="text-center py-2">
                <div id="timer-display" class="text-6xl font-black text-gray-800 tracking-wider">25:00</div>
                <div id="mode-display" class="text-xs font-black text-green-500 mt-1 uppercase tracking-widest">FOCUS TIME</div>
            </div>

            <!-- 포모도로 4단계 알 품기 진척 트래커 -->
            <div class="bg-gray-50 rounded-2xl p-3 border border-gray-200">
                <div class="flex justify-between text-[11px] font-black text-gray-400 uppercase tracking-wider mb-2">
                    <span>오늘의 포모도로 알 품기</span>
                    <span id="round-status">Round 1 / 4</span>
                </div>
                <div class="grid grid-cols-4 gap-2" id="round-slots">
                    <!-- 스크립트에서 알 상태가 동적으로 바뀝니다 -->
                </div>
            </div>

            <!-- 타이머 조작부 -->
            <div class="grid grid-cols-2 gap-3">
                <button id="btn-start" class="btn-duo-green text-white py-3.5 px-4 rounded-2xl font-black text-lg focus:outline-none shadow-sm">
                    공부 시작!
                </button>
                <button id="btn-reset" class="btn-duo-gray py-3.5 px-4 rounded-2xl font-black text-lg focus:outline-none shadow-sm">
                    초기화
                </button>
            </div>
        </div>
    </main>

    <!-- 사육장 및 도감 관리 뷰 (기본적으로 숨겨짐) -->
    <main id="view-sanctuary" class="w-full max-w-md flex-1 flex flex-col my-4 space-y-4 hidden">
        <div class="bg-white p-5 rounded-3xl border-2 border-gray-200 space-y-4">
            <div class="flex justify-between items-center">
                <h3 class="text-lg font-black text-gray-800">🏡 나의 듀오 컬렉션</h3>
                <div class="bg-amber-100 text-amber-800 font-bold px-3 py-1 rounded-full text-xs">
                    🪙 <span id="fp-balance">0</span> FP
                </div>
            </div>
            <p class="text-xs text-gray-500 leading-relaxed">
                집중 세션을 클리어할 때마다 해당 라운드의 유니크 알을 얻고 성장을 위한 FP 포인트를 받습니다. 듀오들을 레벨업하여 나뭇잎 왕관을 쓴 궁극의 듀오로 성장시켜 보세요!
            </p>

            <!-- 듀오 보관 목록 -->
            <div id="sanctuary-list" class="space-y-3 max-h-96 overflow-y-auto pr-1">
                <!-- 획득하고 키우는 듀오 캐릭터들이 나열됩니다 -->
            </div>
        </div>
    </main>

    <!-- 하단 부가 제어판 및 가이드라인 -->
    <footer class="w-full max-w-md bg-white p-4 rounded-2xl border-2 border-gray-200 space-y-4">
        <!-- 스파르타식 집중 가이드라인 -->
        <div class="bg-amber-50 p-3 rounded-xl border border-amber-200 text-xs text-amber-800 space-y-1 leading-relaxed">
            <p class="font-bold">🚨 듀오링고 포모도로 절대 수칙:</p>
            <p>타이머 시작 후 **다른 인터넷 탭으로 이동**하거나 **바탕화면으로 내려놓는 등 이탈**하면, 듀오가 즉시 **칼을 든 비상 모드**로 각성하여 체력이 깎입니다. 인내심이 0%가 되면 가차없이 아웃당합니다!</p>
        </div>

        <!-- 커스텀 시간 세팅 아코디언 -->
        <div class="border-t border-gray-100 pt-3 space-y-3 text-sm">
            <div class="flex justify-between items-center text-xs font-black text-gray-500 uppercase tracking-widest">
                <span>포모도로 시간 설정 (분)</span>
                <span class="text-[10px] text-green-600 font-bold">*수정 즉시 반영</span>
            </div>
            <div class="grid grid-cols-3 gap-2">
                <div>
                    <label class="block text-[10px] font-bold text-gray-400 mb-1">집중 시간</label>
                    <input type="number" id="input-focus" value="25" min="1" max="120" class="w-full p-2 border-2 border-gray-200 rounded-xl text-center font-bold text-gray-700 focus:border-[#58cc02] focus:outline-none">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-gray-400 mb-1">짧은 휴식</label>
                    <input type="number" id="input-short" value="5" min="1" max="30" class="w-full p-2 border-2 border-gray-200 rounded-xl text-center font-bold text-gray-700 focus:border-sky-500 focus:outline-none">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-gray-400 mb-1">긴 휴식</label>
                    <input type="number" id="input-long" value="15" min="1" max="60" class="w-full p-2 border-2 border-gray-200 rounded-xl text-center font-bold text-gray-700 focus:border-indigo-500 focus:outline-none">
                </div>
            </div>

            <!-- 사운드 토글 및 테스트 전용 60배속 컨트롤러 -->
            <div class="flex justify-between items-center pt-1 border-t border-gray-100">
                <div class="flex items-center space-x-2">
                    <span class="text-xs font-bold text-gray-400">사운드 효과:</span>
                    <button id="btn-sound-toggle" class="px-2.5 py-1 text-[10px] font-bold rounded-full bg-green-100 text-green-700 border border-green-300">ON 🔊</button>
                </div>
                
                <div class="flex items-center space-x-1">
                    <label for="dev-speed" class="text-xs font-bold text-gray-400 cursor-pointer">⚡ 테스트용 60배속</label>
                    <input type="checkbox" id="dev-speed" class="w-4 h-4 text-green-600 bg-gray-100 rounded border-gray-300 focus:ring-green-500">
                </div>
            </div>
        </div>
    </footer>

    <!-- 모달 팝업 레이아웃 (보상 획득 및 아웃 알림 전용) -->
    <div id="gameover-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden flex flex-col items-center justify-center p-6 text-center">
        <div class="bg-white rounded-3xl p-8 max-w-sm w-full border-4 border-red-500 space-y-6">
            <div class="text-6xl" id="modal-emoji">🔪</div>
            <h2 id="modal-title" class="text-2xl font-black text-red-600">제 인내심의 한계입니다.</h2>
            <p id="gameover-reason" class="text-sm font-bold text-gray-600 leading-relaxed">
                "스페인어 하루 학습보다 집중 25분이 더 아깝다는 소립니까? 전 이제 침대 밑에 숨어서 당신을 영원히 감시할 겁니다."
            </p>

            <!-- 1단계 보상 전용 선택 박스 -->
            <div id="reward-choices" class="hidden grid grid-cols-1 gap-3 pt-2">
                <button id="btn-reward-rest" class="btn-duo-blue text-white py-3 px-4 rounded-xl font-bold text-sm flex items-center justify-between">
                    <span>☕ 10분 추가 휴식권 받기</span>
                    <span class="bg-white/20 px-2 py-0.5 rounded text-xs">+10m Rest</span>
                </button>
                <button id="btn-reward-points" class="btn-duo-green text-white py-3 px-4 rounded-xl font-bold text-sm flex items-center justify-between">
                    <span>🧪 듀오 영양 포인트 받기</span>
                    <span class="bg-white/20 px-2 py-0.5 rounded text-xs">+100 FP</span>
                </button>
            </div>

            <button id="btn-restart" class="w-full btn-duo-danger text-white py-3.5 rounded-2xl font-black shadow-sm">
                다시는 안 그러겠습니다
            </button>
        </div>
    </div>

    <!-- Firebase 모듈 로드 및 로컬 데이터 동기화 연동 -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, getDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        let db = null;
        let auth = null;
        let userId = null;
        const appId = 'duo-pomo-v2';

        /* -----------------------------------------
         * STREAMING_CHUNK: Designing 5-color theme configurations
         * ----------------------------------------- */
        const DUO_THEMES = {
            classic: {
                name: "오리지널 초록",
                main: "#78C800",
                border: "#58A600",
                light: "#A1E44D",
                shadow: "#2C5400"
            },
            blue: {
                name: "오션 딥블루",
                main: "#1CB0F6",
                border: "#1899EB",
                light: "#84D8FF",
                shadow: "#0A4E7A"
            },
            pink: {
                name: "라즈베리 핑크",
                main: "#FF5858",
                border: "#D32F2F",
                light: "#FF8A8A",
                shadow: "#7A1414"
            },
            purple: {
                name: "미스터리 퍼플",
                main: "#A855F7",
                border: "#7E22CE",
                light: "#D8B4FE",
                shadow: "#4A148C"
            },
            orange: {
                name: "썬셋 오렌지",
                main: "#FF9600",
                border: "#D97706",
                light: "#FFC04D",
                shadow: "#7A3B00"
            }
        };

        const THEME_KEYS = Object.keys(DUO_THEMES);

        // 첫 번째 라운드는 무조건 초록색이며, 그 다음 라운드들은 중복 없이 섞이는 컬러 발생기
        function generateRoundColors() {
            const others = ['blue', 'pink', 'purple', 'orange'];
            for (let i = others.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                const temp = others[i];
                others[i] = others[j];
                others[j] = temp;
            }
            return ['classic', ...others];
        }

        /* -----------------------------------------
         * STREAMING_CHUNK: Crafting scalable high-fidelity SVGs for each stage
         * ----------------------------------------- */
        function getDuoSvg(stage, themeKey = 'classic') {
            const theme = DUO_THEMES[themeKey] || DUO_THEMES.classic;
            const main = theme.main;
            const border = theme.border;
            const light = theme.light;
            const shadow = theme.shadow;

            // Stage 1: 무늬가 선명한 무작위 알
            if (stage === 1) {
                return `
                <svg viewBox="0 0 200 200" class="w-full h-full egg-shake">
                    <ellipse cx="100" cy="170" rx="42" ry="8" fill="#e2e8f0" />
                    <ellipse cx="100" cy="110" rx="52" ry="68" fill="${main}" stroke="${border}" stroke-width="6" />
                    <ellipse cx="100" cy="110" rx="35" ry="45" fill="${light}" opacity="0.8" />
                    <ellipse cx="80" cy="80" rx="8" ry="12" fill="${border}" />
                    <ellipse cx="120" cy="130" rx="10" ry="15" fill="${border}" />
                    <ellipse cx="70" cy="125" rx="6" ry="9" fill="${border}" />
                </svg>`;
            }

            // Stage 2: 서서히 금이 가며 엿보는 듯한 깨진 알
            if (stage === 2) {
                return `
                <svg viewBox="0 0 200 200" class="w-full h-full egg-shake">
                    <ellipse cx="100" cy="170" rx="42" ry="8" fill="#e2e8f0" />
                    <ellipse cx="100" cy="110" rx="52" ry="68" fill="${main}" stroke="${border}" stroke-width="6" />
                    <ellipse cx="100" cy="110" rx="35" ry="45" fill="${light}" opacity="0.8" />
                    <ellipse cx="80" cy="80" rx="8" ry="12" fill="${border}" />
                    <ellipse cx="120" cy="130" rx="10" ry="15" fill="${border}" />
                    <path d="M100,42 L105,70 L95,85 L110,110 L90,130 L100,178" fill="none" stroke="${shadow}" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                    <circle cx="105" cy="98" r="6" fill="#111" />
                    <circle cx="106" cy="96" r="2" fill="white" />
                    <polygon points="103,103 97,108 107,108" fill="#FF9600" />
                </svg>`;
            }

            // Stage 3: 귀여운 얼굴의 어린 아기 듀오
            if (stage === 3) {
                return `
                <svg viewBox="0 0 200 200" class="w-full h-full">
                    <ellipse cx="100" cy="175" rx="45" ry="8" fill="#e2e8f0" />
                    <circle cx="82" cy="166" r="10" fill="#FF9600" />
                    <circle cx="118" cy="166" r="10" fill="#FF9600" />
                    <rect x="55" y="65" width="90" height="100" rx="45" fill="${main}" stroke="${border}" stroke-width="5" />
                    <path d="M 55,90 Q 60,45 80,68 Z" fill="${main}" stroke="${border}" stroke-width="3" />
                    <path d="M 145,90 Q 140,45 120,68 Z" fill="${main}" stroke="${border}" stroke-width="3" />
                    <path d="M 62,115 C 62,95 80,88 100,102 C 120,88 138,95 138,115 C 138,135 120,132 100,122 C 80,132 62,135 62,115 Z" fill="${light}" />
                    <circle cx="84" cy="112" r="16" fill="white" />
                    <circle cx="116" cy="112" r="16" fill="white" />
                    <circle cx="88" cy="112" r="7" fill="#4B4B4B" />
                    <circle cx="112" cy="112" r="7" fill="#4B4B4B" />
                    <circle cx="86" cy="109" r="2.5" fill="white" />
                    <circle cx="110" cy="109" r="2.5" fill="white" />
